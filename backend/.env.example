PORT=4000
NODE_ENV=development

# PostgreSQL connection. Either set DATABASE_URL, or the discrete PG* vars below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smarttrack
PGSSL=false

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed CORS origins (the Vite dev server + deployed frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
